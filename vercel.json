{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "recolor.cz"
        }
      ],
      "destination": "https://www.recolor.cz/$1",
      "permanent": true
    },
    {
      "source": "/test",
      "destination": "https://test.recolor.cz",
      "permanent": false
    },
    {
      "source": "/test/(.*)",
      "destination": "https://test.recolor.cz/$1",
      "permanent": false
    },
    {
      "source": "/graficke-navrhy",
      "destination": "https://test.recolor.cz/graficke-navrhy",
      "permanent": false
    },
    {
      "source": "/tiskove-sluzby",
      "destination": "https://test.recolor.cz/tiskove-sluzby",
      "permanent": false
    },
    {
      "source": "/polepy-ze-samolepek",
      "destination": "https://test.recolor.cz/polepy-ze-samolepek",
      "permanent": false
    },
    {
      "source": "/tvorba-webovych-stranek",
      "destination": "https://test.recolor.cz/tvorba-webovych-stranek",
      "permanent": false
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true
}
